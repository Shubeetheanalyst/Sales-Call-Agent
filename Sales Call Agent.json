        "url": "https://api.retellai.com/v2/create-phone-call",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer key_0f5c9b5d1c68168691057d41ef1c"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from_number\": \"+19896935196\",\n  \"to_number\": \"{{ $json.normalizedPhone }}\",\n  \"override_agent_id\": \"agent_be8c1e0b76084db08f138e3246\",\n  \"retell_llm_dynamic_variables\": {\n    \"client_name\": \"{{ $json['Full Name'] }}\",\n    \"business_name\": \"{{ $json['Business Name'] }}\",\n    \"industry\": \"{{ $json['Industry / Business Type'] }}\",\n    \"email\": \"{{ $json['Email Address'] }}\",\n    \"problem_statement\": \"{{ $json['What problem are you trying to solve?'] }}\",\n    \"country\": \"{{ $json.countryResolved }}\"\n  }\n}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "88938ac9-5f34-4bee-98ac-58e7237a75e8",
      "name": "Retell AI - Initiate Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        16,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nreturn [{\n  json: {\n    status: data.call_status,\n    call_id: data.call_id,\n    \n    client_name: data.retell_llm_dynamic_variables?.client_name,\n    email: data.retell_llm_dynamic_variables?.email,\n    business_name: data.retell_llm_dynamic_variables?.business_name,\n    industry: data.retell_llm_dynamic_variables?.industry,\n    \n    phone: data.to_number,\n    from_number: data.from_number,\n    \n    call_summary: data.call_analysis?.call_summary,\n    call_successful: data.call_analysis?.call_successful,\n    sentiment: data.call_analysis?.user_sentiment,\n    \n    duration_sec: Math.round(data.duration_ms / 1000),\n    \n    recording: data.recording_url,\n    transcript: data.transcript,\n    \n    start_time: new Date(data.start_timestamp).toISOString(),\n    end_time: new Date(data.end_timestamp).toISOString(),\n    \n    meeting_booked: data.call_analysis?.custom_analysis_data?.meeting_booked || false,\n    meeting_time: data.call_analysis?.custom_analysis_data?.meeting_time || null\n  }\n}];"
      },
