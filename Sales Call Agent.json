    {
      "parameters": {
        "jsCode": "// Map country name to international dial code\nconst countryDialCodes = {\n  'Pakistan': '+92',\n  'United States': '+1',\n  'United Kingdom': '+44',\n  'United Arab Emirates': '+971',\n  'Saudi Arabia': '+966',\n  'India': '+91',\n  'Canada': '+1',\n  'Australia': '+61',\n  'Germany': '+49',\n  'France': '+33',\n  'Other': '+1'\n};\n\nconst country = $input.first().json['Country'];\nconst dialCode = countryDialCodes[country] || '+1';\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    dialCode: dialCode,\n    countryResolved: country\n  }\n}];"
      },
      "id": "cc189c94-ed6c-441e-854d-f6a6c8502419",
      "name": "Map Country to Dial Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        272
      ]
    },
    {
      "parameters": {
        "jsCode": "// Normalize phone number to E.164 format required by Retell AI\nconst rawPhone = $input.first().json['Phone Number'] || '';\nconst dialCode = $input.first().json.dialCode || '+1';\n\n// Strip all non-digit characters\nlet digits = rawPhone.replace(/\\D/g, '');\n\n// Remove leading zeros (common in local formats like 0300...)\nif (digits.startsWith('0')) {\n  digits = digits.substring(1);\n}\n\n// Build E.164 number\nlet normalizedPhone;\nif (rawPhone.trim().startsWith('+') || rawPhone.trim().startsWith('00')) {\n  normalizedPhone = '+' + digits;\n} else {\n  normalizedPhone = dialCode + digits;\n}\n\n// Validate: E.164 should be 7–15 digits after the +\nconst digitCount = normalizedPhone.replace('+', '').length;\nconst isValid = digitCount >= 7 && digitCount <= 15;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    normalizedPhone: normalizedPhone,\n    phoneValid: isValid,\n    phoneDigitCount: digitCount\n  }\n}];"
      },
      "id": "a83059a3-81a9-4c52-a538-6c4b26eb57ea",
      "name": "Normalize Phone Number",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
