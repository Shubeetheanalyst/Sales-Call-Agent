    {
      "parameters": {
        "jsCode": "// Log leads with invalid phone numbers for manual follow-up\nconst data = $input.first().json;\n\nreturn [{\n  json: {\n    status: 'PHONE_INVALID',\n    reason: `Phone has ${data.phoneDigitCount} digits — E.164 requires 7–15`,\n    clientName: data['Full Name'],\n    businessName: data['Business Name'],\n    email: data['Email Address'],\n    rawPhone: data['Phone Number'],\n    normalizedPhone: data.normalizedPhone,\n    country: data.countryResolved,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
